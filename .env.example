# Copy this file to .env and fill in a valid Hugging Face token before publishing.
# The default dataset repo also carries prompt-pack provenance and optional
# RL-preference artifacts; no separate preferences repo is required.

HF_TOKEN=hf_your_token_here
HF_NAMESPACE=acidsound
HF_MODEL_REPO=acidnet_model
HF_DATASET_REPO=acidnet_dataset
HF_PRIVATE=true
